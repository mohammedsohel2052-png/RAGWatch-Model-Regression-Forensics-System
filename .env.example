# ── LLM Backend ──────────────────────────────────────────────────────────────
# Options: auto | ollama | openai | stub
# "auto" tries Ollama first, then OpenAI, then falls back to stub (no API key)
GENERATOR_BACKEND=auto

# Required only when GENERATOR_BACKEND=openai or auto (and Ollama is not running)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Ollama model name (default: llama3.2:3b)
# OLLAMA_MODEL=llama3.2:3b

# Optional: OpenAI model name (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ── Alerting ──────────────────────────────────────────────────────────────────
# Optional: Slack incoming webhook URL for regression alerts
# Create one at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
